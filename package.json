{
  "name": "base-47",
  "version": "1.0.0",
  "description": "Base 47 Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "node DISCORD/47-main/47-main/server/index.js",
    "desktop": "electron .",
    "dev": "npm run build:client && node server/server.js",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "cd server && npm install",
    "build:discord": "cd DISCORD/47-main/47-main && npm install && cd client && npm install && npm run build",
    "build": "npm run build:client && npm run build:server",
    "build:exe": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.base47.desktop",
    "productName": "Base 47",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "client/dist/**/*"
    ]
  },
  "dependencies": {
    "ansi-styles": "^6.2.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "discord-html-transcripts": "^3.2.0",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.13.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3"
  }
}
