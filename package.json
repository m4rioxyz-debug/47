{
  "name": "base-47",
  "version": "1.0.0",
  "description": "Base 47 Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "node server/server.js",
    "desktop": "electron .",
    "dev": "npm run build:client && node server/server.js",
    "build:client": "cd client && npm install && npm run build",
    "build:server": "cd server && npm install",
    "build": "npm run build:client && npm run build:server",
    "build:exe": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.base47.desktop",
    "productName": "Base 47",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "client/dist/**/*"
    ]
  },
  "dependencies": {
    "ansi-styles": "^6.2.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3"
  }
}
